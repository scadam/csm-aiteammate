# CSM AI Teammate — local configuration template.
# Copy to .env and fill in. NEVER commit real secrets. (.env is gitignored.)
#
# The Entra app registrations referenced below (agent's own identity, blueprint,
# OBO connection) are created with the `a365` CLI — see A365_SDK_AND_CLI_GUIDE.md,
# Part 1. Copy the resulting client/tenant ids here; do not create them by hand.

# --- Agent's OWN identity (Azure Bot / Entra app registration) ---
# For the control-plane "Accept & send" path to actually deliver customer email
# (app-only `/users/{manager}/sendMail`), grant this app the Microsoft Graph
# **Mail.Send** APPLICATION permission and admin-consent it. The bot/agent path
# sends via Work IQ OBO (`/me/sendMail`) and does not need this.
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=

# --- OBO exchange connection (acts on behalf of the manager) ---
CONNECTIONS__OBO__SETTINGS__CLIENTID=
CONNECTIONS__OBO__SETTINGS__CLIENTSECRET=
CONNECTIONS__OBO__SETTINGS__TENANTID=

# --- User authorization handlers ---
AGENTAPPLICATION__USERAUTHORIZATION__AUTOSIGNIN=true
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__OBO__SETTINGS__AZUREBOTOAUTHCONNECTIONNAME=
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__OBO__SETTINGS__OBOCONNECTIONNAME=OBO
# Agentic user-authorization handler — mints the agent's own agentic-user token,
# used to (a) export A365 observability and (b) proactively 1:1-message the manager.
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__TYPE=AgenticUserAuthorization

# --- Manager assignment (each instance has exactly one manager) ---
AGENT__MANAGER__USER_ID=csm-svasireddy
AGENT__IDENTITY__AGENT_ID=          # the agent's own Entra Agent ID
AGENT__IDENTITY__BLUEPRINT_ID=      # the Entra blueprint app id
AGENT__IDENTITY__TENANT_ID=
AGENT__DISPLAY_NAME=CSM AI Teammate
AGENT__OBO__HANDLER_ID=OBO
AGENT__GITHUB__HANDLER_ID=GITHUB
AGENT__AGENTIC__HANDLER_ID=AGENTIC
# Delegated Graph scope used when the agent proactively messages its manager (1:1 Teams chat).
# AGENT__AGENTIC__GRAPH_SCOPE=https://graph.microsoft.com/.default
# Proactive manager notifications (HITL escalation as a 1:1 Teams message).
AGENT__NOTIFICATIONS__ENABLE=true

# --- Agentic identity (the agent's OWN token; acts AS the agent, not the manager) ---
# Lets the agent act for autonomous / system-triggered work (sweeps, timers, signals)
# as its own governed Entra Agent ID — minted with NO turn context via the SDK
# agentic-user federation (client-credentials / user_fic, not OBO). OBO is still used
# only when acting as the manager (the manager's own M365 data). Set the instance ids
# to pin a single instance; leave blank to resolve them per-manager from live discovery.
AGENT__AGENTIC_IDENTITY__ENABLE=true
# AGENT__IDENTITY__INSTANCE_APP_ID=   # the per-instance Entra app id to mint tokens for
# AGENT__IDENTITY__AGENTIC_USER_ID=   # the agent-user object id to mint tokens for

# --- GitHub Copilot SDK (agentic loop) ---
# Model is an Azure OpenAI DEPLOYMENT name when COPILOT_PROVIDER=azure.
# COPILOT_MODEL=gpt-5.4-1
# COPILOT_PROVIDER=azure              # azure = BYOK Azure OpenAI via managed identity (no GitHub token,
#                                     #         no premium requests); github = GitHub Copilot identity
# COPILOT_ENABLE_SKILLS=true          # let the SDK discover src/skills/<name>/SKILL.md natively
# GITHUB_TOKEN=                       # only used when COPILOT_PROVIDER=github (local/dev)

# --- Azure OpenAI (agentic loop provider + NL-to-SQL + drafts; managed identity, never key-based; not Cortex) ---
AZURE_OPENAI_ENDPOINT=                # https://<resource>.openai.azure.com/openai/v1/
# AZURE_OPENAI_SCOPE=https://cognitiveservices.azure.com/.default
# AZURE_OPENAI_API_VERSION=2024-10-21 # data-plane API version for the Copilot BYOK Azure provider
# AZURE_OPENAI_SQL_DEPLOYMENT=gpt-5.4-1
# AZURE_OPENAI_DRAFT_DEPLOYMENT=gpt-5.4-1
# Token-based cost: $ per 1,000,000 tokens. Only API-verified models are priced by default
# (gpt-4o). Supply exact contracted prices for other models here; unpriced models report no
# dollar cost (never fabricated). Example:
# AOAI_MODEL_PRICES={"gpt-5.4":{"input":<in_per_1M>,"output":<out_per_1M>}}

# --- Snowflake (relational back end). Leave SNOWFLAKE_ACCOUNT blank to use the
#     in-memory SQLite simulation seeded from data/*.json. Key-pair auth preferred. ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PRIVATE_KEY_PATH=secrets/rsa_key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
# SNOWFLAKE_PASSWORD=                 # fallback only; key-pair preferred
SNOWFLAKE_DATABASE=CSM_DB
SNOWFLAKE_SCHEMA=ADOPTION
SNOWFLAKE_WAREHOUSE=GIM_WH
SNOWFLAKE_ROLE=GIM_AGENT_ROLE        # runtime role: READ-ONLY
SNOWFLAKE_ADMIN_ROLE=SYSADMIN        # used ONLY by scripts/load_data.py (DDL + grants)

# --- A365 Tooling Gateway ---
A365__TOOLING_GATEWAY__URL=
A365__TOOLING_GATEWAY__REGISTRATION_ID=
# Gateway endpoint the Copilot loop consumes for the custom (BYO) MCP server once approved.
A365__TOOLING_GATEWAY__MCP_ENDPOINT=

# Real Agent 365 instance discovery (Entra). Leave unset until per-CSM agent instances exist;
# the technical view then shows an honest empty state. Set to an OData $filter over
# /servicePrincipals to surface real instances, e.g.:
# A365__INSTANCE__SP_FILTER=startswith(displayName,'CSM Autopilot ')
A365__INSTANCE__SP_FILTER=

# --- Custom (BYO) MCP server registration on the A365 Tooling Gateway ---
# Public HTTPS URL of this agent's MCP server (e.g. a tunnel). Required to register BYO.
MCP__PUBLIC_URL=
MCP__SERVER_NAME=ext_CsmTeammate

# --- Gainsight NXT (simulated-real REST). Real contracts, served from data/*.json.
#     Set GAINSIGHT__LIVE=true + a real domain/access key to call the live API. ---
GAINSIGHT__DOMAIN=https://companyapi.gainsightcloud.com
GAINSIGHT__ACCESS_KEY=simulated-access-key
GAINSIGHT__PX_API_KEY=simulated-px-key
GAINSIGHT__LIVE=false

# --- Work IQ MCP (REAL Microsoft 365 grounding; consumed as a remote MCP server via OBO) ---
# Work IQ is Microsoft Entra DELEGATED-ONLY (no app-only), so it grounds on the manager's behalf
# only when a signed-in manager turn is present (the bot/agent host). Blank WORKIQ__MCP__ENDPOINT
# to skip the Work IQ path. The SERVER-SIDE control plane (no user turn) grounds instead by reading
# the manager's REAL mailbox + calendar via Microsoft Graph using the host's MANAGED IDENTITY —
# grant the control-plane managed identity the Graph APPLICATION permissions Mail.Read + Calendars.Read
# (admin-consented). If neither is available, the agent falls back to the offline data/workiq.json fixture.
WORKIQ__MCP__ENDPOINT=https://workiq.svc.cloud.microsoft/mcp
WORKIQ__SCOPE=api://workiq.svc.cloud.microsoft/WorkIQAgent.Ask
WORKIQ__APP_ID=fdcc1f02-fc51-4226-8753-f668596af7f7

# --- Microsoft Purview (DSPM for AI) + security suite ---
# DSPM evaluation of prompts/responses/grounding runs via Graph processContent (real
# when a manager OBO or the host managed identity can reach Graph). See src/purview.py.
ENABLE_PURVIEW=true
# Log every agent/MCP tool call to DSPM as a real processContent "Tool call" event so
# tool activity is visible in Purview Activity explorer + the dashboard. Set false to
# reduce processContent volume/cost.
PURVIEW__LOG_TOOL_CALLS=true
# The agent's Entra app id used as the Purview policyLocationApplication (defaults to the
# blueprint app id). Must match the -AppId passed to scripts/setup_purview_dlp.ps1.
# PURVIEW__APP_LOCATION_ID=
# Name of the DLP-for-AI policy created by scripts/setup_purview_dlp.ps1. Set this so the
# Technical & governance dashboard shows the platform DLP layer as configured.
# PURVIEW__DLP_POLICY=CSM Autopilot AI DLP
# PURVIEW__CONFIDENTIAL_SIT=Customer Confidential ID

# --- A365 Observability (OTEL / OTLP gRPC) ---
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Durable cost ledger (Azure Table Storage; managed identity, never a key) ---
# Table-service endpoint of a storage account the control-plane identity can reach
# (needs "Storage Table Data Contributor"). When set, per-job inference cost points
# are persisted so the cost/token chart survives container recycles. Leave blank to
# keep cost history in memory only (lost on recycle).
# COST_STORE__TABLE_ENDPOINT=https://<account>.table.core.windows.net

# --- A365 Observability SDK toggles (both must be true for real export) ---
ENABLE_A365_OBSERVABILITY=false
ENABLE_A365_OBSERVABILITY_EXPORTER=false
# A365_OBSERVABILITY_DOMAIN_OVERRIDE=

# --- Hosting ---
PORT=3978
MCP_HOST=127.0.0.1
MCP_PORT=8000
SIGNAL_SEVERITY_THRESHOLD=3
