# Keep the build context small and never ship secrets or local state.
.git/
.github/
.venv/
venv/
__pycache__/
**/__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

# Secrets & local config — provided to the container via Container App secrets/env, never baked in.
.env
.env.*
secrets/
*.p8
*.pem

# Tests, docs, scratch, infra, build artefacts
tests/
infra/
*.md
tmp_*.py
tmp/
byo-mcp-registration.json
a365.generated.config.json
*.PDF
*.pdf
