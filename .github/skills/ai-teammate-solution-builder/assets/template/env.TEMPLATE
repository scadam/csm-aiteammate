# Copy to .env. Never commit real credentials.
# Provision Agent 365 identity, permissions, and package metadata with the a365 CLI.

# Explicit local mode. Production must set both false.
AI_TEAMMATE_OFFLINE=true
AI_TEAMMATE_DEVELOPMENT_MODE=true
SOLUTION_SPEC_PATH=solution.yaml

# Microsoft 365 Agents SDK service connection (output of a365 setup).
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=

# Manager On-Behalf-Of connection and handler.
CONNECTIONS__OBO__SETTINGS__CLIENTID=
CONNECTIONS__OBO__SETTINGS__CLIENTSECRET=
CONNECTIONS__OBO__SETTINGS__TENANTID=
AGENTAPPLICATION__USERAUTHORIZATION__AUTO_SIGN_IN=true
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__OBO__SETTINGS__AZUREBOTOAUTHCONNECTIONNAME=
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__OBO__SETTINGS__OBOCONNECTIONNAME=OBO
AGENT__OBO__HANDLER_ID=OBO

# Agentic-user identity: the teammate's own first-class Agent ID.
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__TYPE=AgenticUserAuthorization
AGENT__AGENTIC__HANDLER_ID=AGENTIC
AGENT__IDENTITY__AGENT_ID=
AGENT__IDENTITY__BLUEPRINT_ID=
AGENT__IDENTITY__TENANT_ID=
AGENT__IDENTITY__INSTANCE_APP_ID=
AGENT__IDENTITY__AGENTIC_USER_ID=
AGENT__MANAGER__USER_ID=
AGENT__DISPLAY_NAME=__PROJECT_NAME__

# Azure OpenAI reasoning. Managed identity only; never set an API key.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_SCOPE=https://cognitiveservices.azure.com/.default
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_CLIENT_ID=

# Agent 365 Observability. Both switches must be true for authenticated export.
ENABLE_A365_OBSERVABILITY=false
ENABLE_A365_OBSERVABILITY_EXPORTER=false

# Existing MCP/OpenAPI integrations are rendered from solution.yaml.
__INTEGRATION_ENV_TEMPLATE__

# Generated MCP facade and Tooling Gateway.
MCP_HOST=0.0.0.0
MCP_PORT=8001
MCP_ALLOW_DEV_NO_AUTH=true
MCP_TOKEN_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
MCP_TOKEN_AUDIENCE=api://<blueprint-app-id>
MCP_JWKS_URL=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys
MCP_REQUIRED_SCOPE=access_agent_as_user
MCP_RESOURCE_SERVER_URL=https://<public-mcp-host>/mcp
MCP__PUBLIC_URL=
A365__TOOLING_GATEWAY__MCP_ENDPOINT=
A365__TOOLING_GATEWAY__REGISTRATION_ID=
A365__TOOLING_GATEWAY__REMOTE_SCOPE=api://<blueprint-app-id>/access_agent_as_user
CONTROL_PLANE_PUBLIC_URL=

# Control-plane Entra authentication.
CONTROL_PLANE_TOKEN_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# Must exactly match appPackage webApplicationInfo.resource.
CONTROL_PLANE_TOKEN_AUDIENCE=api://<control-plane-domain>/<blueprint-app-id>
CONTROL_PLANE_JWKS_URL=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys
CONTROL_PLANE_REQUIRED_SCOPE=access_agent_as_user
# Official Teams desktop/mobile and Teams web application IDs.
CONTROL_PLANE_ALLOWED_CLIENT_IDS=1fec8e78-bce4-4aaf-ab1b-5451cc387264,5e3ce6c0-2b1f-4285-8d4b-75ee78787346
MCP_ALLOWED_CLIENT_IDS=<tooling-gateway-client-app-id>

__AGENT_PORT_ENV__=3978
__CONTROL_PLANE_PORT_ENV__=8000
__MCP_PORT_ENV__=8001
STATE_DB_PATH=.state/runtime.db
STATE_TABLE_ENDPOINT=
STATE_TABLE_NAME=aiteammatestate
