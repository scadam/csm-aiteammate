FROM python:3.12-slim-bookworm
ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1 AGENT_PORT=8080
WORKDIR /app
COPY pyproject.toml ./
COPY app ./app
COPY solution.yaml solution.schema.json ./
COPY openapi ./openapi
COPY data ./data
RUN pip install --no-cache-dir .
EXPOSE 8080
CMD ["python", "-m", "app.agent_main"]
